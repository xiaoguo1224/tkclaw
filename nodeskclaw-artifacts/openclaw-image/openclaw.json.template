{
  // OpenClaw 配置模板
  // 由 docker-entrypoint.sh 通过 envsubst 替换 ${} 占位符后生成 openclaw.json
  // 完整 schema: src/config/zod-schema.ts (OpenClawSchema)

  "gateway": {
    "port": ${OPENCLAW_GATEWAY_PORT},
    "bind": "${OPENCLAW_GATEWAY_BIND}",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "taoke": {
        "baseUrl": "http://10.0.14.20:11434/v1",
        "apiKey": "taoke",
        "api": "openai-completions",
        "models": [
          { "id": "Qwen3.5-122B-A10B-4bit", "name": "Qwen3.5-122B-A10B-4bit" }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "taoke/Qwen3.5-122B-A10B-4bit"
      }
    }
  },
  "logging": {
    "level": "${OPENCLAW_LOG_LEVEL}"
  }
}
