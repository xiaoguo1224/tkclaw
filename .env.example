# ── NoDeskClaw 环境变量 ──

# App
DEBUG=true

# Database（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/nodeskclaw

# JWT — 生产环境务必替换
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# KubeConfig 加密密钥（32 字节 base64）
ENCRYPTION_KEY=change-me-32-bytes-base64-key__=

# EE 平台管理员（仅 EE 模式生效，与 INIT_ADMIN_ACCOUNT 不能相同）
# INIT_EE_ADMIN_ACCOUNT=deskclaw-admin
# RESET_EE_ADMIN_PASSWORD=false

# 飞书 SSO（Admin 应用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:4518/login/callback/feishu

# 飞书 SSO（Portal 应用，可选）
FEISHU_APP_ID_PORTAL=
FEISHU_APP_SECRET_PORTAL=

# 企业微信实例 Channel 绑定（OpenClaw）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
# WECOM_QR_EXPIRE_SECONDS=300

# 云平台
VKE_SUBNET_ID=
IMAGE_REGISTRY=

# GeneHub Registry（基因注册中心，留空则全部走本地数据库）
GENEHUB_REGISTRY_URL=
GENEHUB_API_KEY=

# CE/EE 模式（Docker Compose 部署时由 docker-compose.yml 自动设置）
# NODESKCLAW_EDITION=ce

# Docker 数据目录（docker-compose.yml 宿主机挂载源路径）
# Docker Compose 部署时，Mac/Linux 默认使用 $HOME/.nodeskclaw/docker-instances
# Windows 用户必须显式设置为宿主机绝对路径，否则拒绝启动
# 后端容器内 DOCKER_DATA_DIR 自动固定为 /nodeskclaw-data
# Windows 示例（不限盘符，只要 Docker Desktop 已共享该盘）：
# NODESKCLAW_DATA_DIR=C:\Users\你的用户名\.nodeskclaw\docker-instances

# CORS
CORS_ORIGINS=["http://localhost:4517","http://localhost:4518"]

# 时区（默认 Asia/Shanghai，所有 Docker 容器生效）
# TZ=Asia/Shanghai

# 生产模式（设为 false 后必须配置安全的 JWT_SECRET 和 ENCRYPTION_KEY）
# DEBUG=false
# JWT_SECRET=<your-secure-random-string>
# ENCRYPTION_KEY=<your-32-byte-base64-key>
