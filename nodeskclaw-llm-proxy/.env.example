# 数据库（与 nodeskclaw-backend 共用同一个 RDS PostgreSQL）
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/nodeskclaw

# 出站代理（用于访问 OpenAI/Anthropic 等外部 API）
# K8s 部署时由 Clash sidecar 提供，设为 http://localhost:7890
# 本地开发时设为本机代理地址
HTTPS_PROXY=http://localhost:7890

# 是否记录完整请求体（request_body），默认关闭
# 开启后会将 LLM 请求原文存入 llm_usage_logs.request_body（含用户消息，属敏感内容）
LLM_LOG_CONTENT=false

# Codex CLI 集成（可选）
# 本地开发默认可直接读取当前用户的 ~/.codex；容器内请将宿主机 ~/.codex 挂载进去
CODEX_COMMAND=codex
CODEX_HOME=
CODEX_SKIP_GIT_REPO_CHECK=true
# 默认关闭，避免绕过 Codex CLI 自带的审批和沙箱保护
# 仅在你明确接受执行风险时再手动改为 true
CODEX_BYPASS_APPROVALS_AND_SANDBOX=false
CODEX_TIMEOUT_SECONDS=300
