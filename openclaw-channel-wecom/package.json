{
  "name": "openclaw-channel-wecom",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw channel plugin for WeCom messaging",
  "type": "module",
  "devDependencies": {
    "openclaw": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wecom",
