# ── NoDeskClaw 环境变量 ──
#
# Docker Compose 部署说明：
#   docker compose up 会启动内置 PostgreSQL，backend 自动连接，无需配置 DATABASE_URL。
#   如需使用外部数据库：在项目根目录创建 .env 文件，设置 DATABASE_URL，
#   然后 docker compose up -d nodeskclaw-backend portal（跳过内置 postgres）。
#   Docker 部署时 DATABASE_NAME_SUFFIX 必须留空（compose 文件已强制覆盖）。

# App
DEBUG=true
# LOG_SQL=true  # 打开后显示 SQLAlchemy SQL 语句（默认关闭，按需开启调试）
# LOG_HEALTH_CHECK=true  # 打印 /health 探针访问日志（默认关闭，错误响应始终打印）

# Database（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/nodeskclaw
# 数据库名后缀（auto = 用本机 hostname，Docker 部署时必须留空）
DATABASE_NAME_SUFFIX=
# DB 连接池（默认值适用于大多数场景）
# DB_POOL_SIZE=10
# DB_POOL_MAX_OVERFLOW=20

# CE 超管（默认 admin，留空则跳过自动创建）
INIT_ADMIN_ACCOUNT=admin
# 设为 true 后重启可强制重置超管密码
RESET_ADMIN_PASSWORD=false

# EE 平台管理员（默认 deskclaw-admin，留空则跳过；与 INIT_ADMIN_ACCOUNT 不能相同）
INIT_EE_ADMIN_ACCOUNT=deskclaw-admin
# 设为 true 后重启可强制重置 EE 管理员密码
RESET_EE_ADMIN_PASSWORD=false

# JWT — 生产环境务必替换
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# KubeConfig 加密密钥（32 字节 base64）
ENCRYPTION_KEY=change-me-32-bytes-base64-key__=

# 飞书 SSO（Admin 应用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:4518/login/callback/feishu

# 飞书 SSO（Portal 应用，可选）
FEISHU_APP_ID_PORTAL=
FEISHU_APP_SECRET_PORTAL=

# 云平台
VKE_SUBNET_ID=

# Egress NetworkPolicy（AI 员工 Pod 出站流量控制）
# [已废弃] EGRESS_DENY_CIDRS / EGRESS_ALLOW_PORTS 已迁移至「组织设置 > 网络路由」页面管理。
# 首次升级时，环境变量值会自动迁移到数据库，之后通过 UI 配置。
# 平台服务所在 namespace（NetworkPolicy 允许实例与该 namespace 双向通信）
# 默认自动检测后端 Pod 所在 namespace，通常无需手动设置
# PLATFORM_NAMESPACE=nodeskclaw-system

# Gene Seed（启动时从本地模板导入种子基因，slug 已存在则跳过）
SEED_GENES=true

# GeneHub（已有默认值 https://skills.deskclaw.me，纯离线模式设为空串）
GENEHUB_REGISTRY_URL=
GENEHUB_API_KEY=
GENEHUB_WEB_URL=

# LLM Proxy（独立 LLM 代理服务）
# 本地开发由 dev.sh 自动覆盖为 http://localhost:4511，Docker 部署由 compose 覆盖
LLM_PROXY_URL=
# K8s 集群内网地址，用于 openclaw.json 中的 baseUrl（绕过 ALB）
LLM_PROXY_INTERNAL_URL=

# 镜像仓库配置已迁移到数据库（Settings 页面管理），不再通过 .env 配置

# S3 兼容对象存储（文件上传功能，不配置则使用本地文件存储）
# 支持 AWS S3、MinIO、阿里云 OSS、火山云 TOS 等任何 S3 兼容服务
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# key 前缀（本地开发可设为 dev，生产留空）
S3_KEY_PREFIX=

# AI 员工回连后端地址（仅管理 Docker 实例时可保持默认 localhost）
# 若管理 K8s 集群上的 AI 员工，必须改为 K8s Pod 可达的外部地址
# AGENT_API_BASE_URL=https://your-nodeskclaw-domain.com/api/v1

# AI 员工 WebSocket 隧道地址（可选，不设则从 AGENT_API_BASE_URL 推导）
# 当 WebSocket 需要走不同入口（如独立的 wss:// 域名）时设置
# TUNNEL_BASE_URL=wss://your-nodeskclaw-domain.com/api/v1/tunnel/connect

# CORS（Docker 部署时改为实际访问地址，如 http://localhost, http://localhost:8001）
CORS_ORIGINS=["http://localhost:4517","http://localhost:4518"]

# 时区（Docker Compose 部署在 docker-compose.yml 中统一配置，此处仅用于本地开发）
# TZ=Asia/Shanghai
